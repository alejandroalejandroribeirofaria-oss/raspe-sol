# Production environment for the Raspe SOL frontend.

VITE_API_URL=https://raspe-sol.onrender.com

# REQUIRED: replace with a paid RPC provider before real traffic. The public
# endpoint is fine for a smoke test but will rate-limit under real usage —
# the wallet-connect flow and balance polling both hit this directly from
# the browser, so it takes load independently of the backend's own RPC.
VITE_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
